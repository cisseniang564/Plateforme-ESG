# Example Kubernetes Secret — DO NOT commit with real values
# Generate base64: echo -n "myvalue" | base64
# Apply: kubectl apply -f secrets.yaml (after filling real values)
apiVersion: v1
kind: Secret
metadata:
  name: esgplatform-secrets
  namespace: esgplatform
type: Opaque
stringData:
  # Database
  POSTGRES_DB: esgflow
  POSTGRES_USER: esgflow
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  DATABASE_URL: postgresql+asyncpg://esgflow:CHANGE_ME@esgplatform-postgres:5432/esgflow

  # Redis
  REDIS_URL: redis://esgplatform-redis:6379/0

  # JWT — generate with: openssl rand -hex 32
  JWT_SECRET_KEY: CHANGE_ME_32_CHAR_SECRET
  APP_SECRET_KEY: CHANGE_ME_32_CHAR_SECRET

  # Sentry (optional)
  SENTRY_DSN: ""

  # OpenAI (optional)
  OPENAI_API_KEY: ""

  # Stripe (optional)
  STRIPE_SECRET_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""

  # App config
  APP_ENV: production
  LOG_LEVEL: INFO
