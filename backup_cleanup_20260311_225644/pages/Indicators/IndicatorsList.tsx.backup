import { useEffect, useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import { Plus, Eye } from 'lucide-react';
import Card from '@/components/common/Card';
import Button from '@/components/common/Button';
import Spinner from '@/components/common/Spinner';
import PageHeader from '@/components/PageHeader';
import api from '@/services/api';

interface Indicator {
  id: string;
  code: string;
  name: string;
  pillar: string;
  category: string;
  unit: string;
  weight: number;
  target_value: number;
  is_active: boolean;
  framework: string;
}

export default function IndicatorsList() {
  const { t } = useTranslation();
  const navigate = useNavigate();
  const [indicators, setIndicators] = useState<Indicator[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedPillar, setSelectedPillar] = useState<string>('all');

  useEffect(() => {
    loadIndicators();
  }, []);

  const loadIndicators = async () => {
    try {
      const response = await api.get('/indicators');
      setIndicators(response.data.indicators || []);
    } catch (error) {
      console.error('Error loading indicators:', error);
    } finally {
      setLoading(false);
    }
  };

  const filteredIndicators = selectedPillar === 'all' 
    ? indicators 
    : indicators.filter(ind => ind.pillar === selectedPillar);

  const getPillarColor = (pillar: string) => {
    const colors = {
      environmental: 'text-green-600 bg-green-50',
      social: 'text-blue-600 bg-blue-50',
      governance: 'text-purple-600 bg-purple-50',
    };
    return colors[pillar as keyof typeof colors] || 'text-gray-600';
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center h-64">
        <Spinner size="lg" />
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <PageHeader
        title={t('indicators.title')}
        subtitle={t('indicators.subtitle')}
        actions={
          <Button onClick={() => navigate('/indicators/new')}>
            <Plus className="h-5 w-5 mr-2" />
            {t('indicators.addIndicator')}
          </Button>
        }
      />

      {/* Filters */}
      <div className="flex gap-2">
        <Button
          variant={selectedPillar === 'all' ? 'primary' : 'secondary'}
          onClick={() => setSelectedPillar('all')}
        >
          {t('indicators.all')}
        </Button>
        <Button
          variant={selectedPillar === 'environmental' ? 'primary' : 'secondary'}
          onClick={() => setSelectedPillar('environmental')}
        >
          {t('indicators.environmental')}
        </Button>
        <Button
          variant={selectedPillar === 'social' ? 'primary' : 'secondary'}
          onClick={() => setSelectedPillar('social')}
        >
          {t('indicators.social')}
        </Button>
        <Button
          variant={selectedPillar === 'governance' ? 'primary' : 'secondary'}
          onClick={() => setSelectedPillar('governance')}
        >
          {t('indicators.governance')}
        </Button>
      </div>

      {/* Indicators Grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredIndicators.map((indicator) => (
          <Card key={indicator.id} className="hover:shadow-lg transition-shadow">
            <div className="space-y-3">
              <div className="flex items-start justify-between">
                <span className="text-sm font-mono text-gray-500 bg-gray-100 px-2 py-1 rounded">
                  {indicator.code}
                </span>
                <span className={`px-2 py-1 text-xs rounded capitalize ${getPillarColor(indicator.pillar)}`}>
                  {t(`pillars.${indicator.pillar}`)}
                </span>
              </div>
              
              <h3 className="font-semibold text-gray-900">{indicator.name}</h3>
              
              <div className="grid grid-cols-2 gap-2 text-sm">
                <div>
                  <p className="text-gray-500">{t('indicators.unit')}</p>
                  <p className="font-medium">{indicator.unit}</p>
                </div>
                <div>
                  <p className="text-gray-500">{t('indicators.weight')}</p>
                  <p className="font-medium">{indicator.weight}</p>
                </div>
              </div>

              {indicator.framework && (
                <p className="text-xs text-gray-500">
                  {t('indicators.framework')}: {indicator.framework}
                </p>
              )}

              <Button
                variant="secondary"
                size="sm"
                className="w-full"
                onClick={() => navigate(`/indicators/${indicator.id}`)}
              >
                <Eye className="h-4 w-4 mr-2" />
                {t('indicators.viewDetails')}
              </Button>
            </div>
          </Card>
        ))}
      </div>

      {filteredIndicators.length === 0 && (
        <Card>
          <div className="text-center py-12">
            <p className="text-gray-500">{t('indicators.noIndicators')}</p>
            <p className="text-sm text-gray-400 mt-2">{t('indicators.createFirst')}</p>
          </div>
        </Card>
      )}
    </div>
  );
}
