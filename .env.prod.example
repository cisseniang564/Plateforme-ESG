# ============================================================
# ESGFlow Platform — Production Environment Variables
# Copy this file to .env.prod and fill in actual values
# NEVER commit .env.prod to version control
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_NAME=ESGFlow Platform
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0
RELOAD=false
LOG_LEVEL=INFO

# ─── Security ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ───────────────────────────────────────────────
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=esgflow
DATABASE_USER=esgflow
DATABASE_PASSWORD=change-me-strong-password
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["https://your-domain.com"]

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=https://your-domain.com/api/v1

# ─── Email (optional) ───────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@your-domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@your-domain.com

# ─── Sentry (optional) ──────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── MinIO / S3 (optional) ──────────────────────────────────
MINIO_HOST=your-minio-host
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=esgflow-uploads
