# ============================================================
# ESGFlow — Production Environment
# Copiez en .env.prod et remplissez les valeurs réelles
# IMPORTANT: Ne jamais commiter .env.prod dans git
# ============================================================

APP_NAME=ESGFlow
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
RELOAD=false
LOG_LEVEL=INFO
API_DOCS_ENABLED=false

# Sécurité — Générer: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Base de données
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=esgflow
DATABASE_USER=esgflow
DATABASE_PASSWORD=CHANGE_ME
DATABASE_POOL_SIZE=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# CORS
CORS_ORIGINS=["https://yourdomain.com"]

# Frontend
VITE_API_URL=https://yourdomain.com/api/v1
FRONTEND_URL=https://yourdomain.com

# Email
RESEND_API_KEY=re_CHANGE_ME
SMTP_FROM=noreply@yourdomain.com

# Sentry
SENTRY_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID

# S3
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=esgflow-uploads

# Stripe (clés LIVE uniquement en production)
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_STARTER_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_STARTER_YEARLY=price_CHANGE_ME
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_PRO_YEARLY=price_CHANGE_ME
